{
  "name": "stylelint-plugin-aurora",
  "version": "2.1.0",
  "description": "Various Stylelint rules in one plugin.",
  "files": [
    "dist",
    "docs"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "release": "release-it",
    "lint": "eslint --fix './**/*.{js,mjs,ts}'",
    "lint:ci": "eslint --max-warnings 0 './**/*.{js,mjs,ts}'",
    "prepack": "tsdown",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CyanSalt/stylelint-plugin-aurora.git"
  },
  "bugs": {
    "url": "https://github.com/CyanSalt/stylelint-plugin-aurora/issues"
  },
  "homepage": "https://github.com/CyanSalt/stylelint-plugin-aurora#readme",
  "keywords": [
    "stylelint",
    "stylelint-plugin"
  ],
  "author": "CyanSalt",
  "license": "ISC",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "error"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "^11.0.0",
        "onFail": "error"
      },
      {
        "name": "npm",
        "onFail": "ignore"
      }
    ]
  },
  "devDependencies": {
    "@cyansalt/eslint-config": "^4.6.0",
    "@cyansalt/tsconfig": "^3.0.2",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/node": "^22.19.17",
    "eslint": "^10.3.0",
    "release-it": "^20.0.1",
    "stylelint": "^17.11.0",
    "stylelint-test-rule-vitest": "^0.1.1",
    "tsdown": "^0.21.10",
    "typescript": "^5.9.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "stylelint": ">=16.0.0"
  },
  "dependencies": {
    "colord": "^2.9.3",
    "magic-string": "^0.30.21",
    "postcss-value-parser": "^4.2.0"
  }
}
